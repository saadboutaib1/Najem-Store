# Browser API base. Production uses same-origin Vercel API functions.
VITE_API_URL=/api

# Server-only Vercel API variables. Do not expose these in browser code.
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=server_only_do_not_expose

# Server-only admin bootstrap variables.
ADMIN_EMAIL=your_admin_email
ADMIN_PASSWORD=your_admin_password
ADMIN_TOKEN_SECRET=your_admin_token_secret

# Local development option:
# If you run only Vite without Vercel functions, remove VITE_API_URL so the app falls back to http://127.0.0.1:8000/api.
# For production-like local API functions, run the frontend through Vercel CLI with these server env vars.